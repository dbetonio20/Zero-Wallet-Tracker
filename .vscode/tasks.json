{
  // For more information, visit: https://go.microsoft.com/fwlink/?LinkId=733558
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "bun: start",
      "command": "bun run start",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "(.*?)"
          },
          "endsPattern": {
            "regexp": "bundle generation complete"
          }
        }
      }
    },
    {
      "type": "shell",
      "label": "bun: build:apk",
      "command": "bun run build:apk",
      "group": "build",
      "isBackground": false,
      "problemMatcher": []
    },
    {
      "type": "shell",
      "label": "bun: build:apk:release",
      "command": "bun run build:apk:release",
      "group": "build",
      "isBackground": false,
      "problemMatcher": []
    },
    {
      "type": "shell",
      "label": "bun: test",
      "command": "bun run test",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "(.*?)"
          },
          "endsPattern": {
            "regexp": "bundle generation complete"
          }
        }
      }
    }
  ]
}
