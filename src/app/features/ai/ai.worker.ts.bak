/**
 * AI Web Worker — runs Transformers.js inference off the main thread.
 *
 * Protocol:
 *   Main → Worker:
 *     { type: 'load' }
 *     { type: 'generate', payload: { messages: { role: string; content: string }[] } }
 *     { type: 'abort' }
 *
 *   Worker → Main:
 *     { type: 'log',      payload: string }
 *     { type: 'progress', payload: { status: string; progress?: number; file?: string } }
 *     { type: 'ready',    payload: { device: string } }
 *     { type: 'token',    payload: string }
 *     { type: 'done',     payload: string }
 *     { type: 'error',    payload: string }
 */

/// <reference lib="webworker" />

import { pipeline, env, TextStreamer } from '@huggingface/transformers';

env.allowLocalModels = false;

// Force single-threaded WASM — Android WebView does not reliably support
// SharedArrayBuffer (required for multi-threaded ONNX), which causes a hard
// crash when the model is loaded into memory.  Single-thread is slower but
// stable on all Android WebView versions.
(env as any).backends = (env as any).backends ?? {};
(env as any).backends.onnx = (env as any).backends.onnx ?? {};
(env as any).backends.onnx.wasm = (env as any).backends.onnx.wasm ?? {};
(env as any).backends.onnx.wasm.numThreads = 1;

// Log the confirmed thread count when worker first runs
setTimeout(() => {
  const actual = (env as any).backends?.onnx?.wasm?.numThreads;
  log(`ONNX WASM numThreads confirmed = ${actual} (1 = single-thread, no SharedArrayBuffer needed)`);
}, 0);

// 0.5B INT4-quantised ONNX model (~350 MB) — fits comfortably in Android WebView memory.
// The original 1.7B model caused OOM crashes on mobile devices.
const MODEL_ID = 'onnx-community/Qwen2.5-0.5B-Instruct';

let generator: any = null;
let abortController: AbortController | null = null;
let activeDevice = 'wasm';

/** Send a log line to the main thread (and also console.log for adb logcat). */
function log(msg: string): void {
  const ts = new Date().toISOString().slice(11, 23);
  const line = `[${ts}] ${msg}`;
  console.log('[ai-worker]', line);
  postMessage({ type: 'log', payload: line });
}

addEventListener('message', async (e: MessageEvent) => {
  const { type, payload } = e.data;
  log(`received message type="${type}"`);

  if (type === 'load') {
    await loadModel();
  } else if (type === 'generate') {
    await generate(payload.messages);
  } else if (type === 'abort') {
    log('abort signal received');
    abortController?.abort();
  }
});

/* ───── helpers ───── */

// WebGPU is intentionally NOT used. While navigator.gpu is present on many
// browsers (desktop Chrome, Android WebView on Snapdragon/Mali), ONNX Runtime
// Web's WebGPU backend hangs indefinitely during the first inference call due
// to shader compilation. WASM is slower per-token but starts reliably.

function progressCb(progress: any): void {
  postMessage({
    type: 'progress',
    payload: {
      status: progress.status ?? 'loading',
      progress: progress.progress ?? undefined,
      file: progress.file ?? undefined,
    },
  });
}

/** Guard against garbled output (common with wrong dtype/backend combo). */
function isValidText(text: string): boolean {
  // If >40% of characters are non-Latin / non-common-punctuation, it's likely garbled
  const valid = text.replace(/[^\x20-\x7E\n\r\t]/g, '');
  return valid.length > text.length * 0.5;
}

/* ───── load ───── */

async function loadModel(): Promise<void> {
  log(`loadModel() start — model=${MODEL_ID}`);

  // Check available memory (Android-only API, may be undefined)
  const mem = (performance as any).memory;
  if (mem) {
    log(`JS heap: used=${(mem.usedJSHeapSize / 1e6).toFixed(1)}MB limit=${(mem.jsHeapSizeLimit / 1e6).toFixed(1)}MB`);
  }

  // Always use WASM — WebGPU hangs on inference (see comment above)
  const attempts: { device: string; dtype: string }[] = [{ device: 'wasm', dtype: 'q4' }];
  log(`will try WASM only (WebGPU disabled — causes infinite hang on inference)`);

  for (const { device, dtype } of attempts) {
    log(`trying device=${device} dtype=${dtype}...`);
    try {
      generator = await (pipeline as any)('text-generation', MODEL_ID, {
        dtype,
        device,
        progress_callback: progressCb,
      });
      activeDevice = device;
      log(`loadModel() SUCCESS — device=${device} dtype=${dtype}`);
      postMessage({ type: 'ready', payload: { device } });
      return;
    } catch (err: any) {
      log(`device=${device} FAILED: ${err?.message ?? String(err)}`);
      // continue to next attempt
    }
  }

  log('loadModel() FAILED on all backends');
  postMessage({ type: 'error', payload: 'Could not load model on any backend.' });
}

/* ───── generate ───── */

async function generate(messages: { role: string; content: string }[]): Promise<void> {
  if (!generator) {
    log('generate() called but generator is null!');
    postMessage({ type: 'error', payload: 'Model not loaded yet.' });
    return;
  }

  log(`generate() start — ${messages.length} messages, device=${activeDevice}`);
  log(`messages: ${JSON.stringify(messages.map(m => ({ role: m.role, len: m.content.length }))).slice(0, 300)}`);
  const startMs = Date.now();
  let tokenCount = 0;
  abortController = new AbortController();

  // Heartbeat: log every 10s so we can tell if it's slow vs stuck
  const heartbeat = setInterval(() => {
    const elapsed = ((Date.now() - startMs) / 1000).toFixed(0);
    log(`heartbeat: ${elapsed}s elapsed, ${tokenCount} tokens so far`);
  }, 10_000);

  try {
    let fullText = '';

    // Token-by-token streaming via callback
    const streamer = new (TextStreamer as any)(generator.tokenizer, {
      skip_prompt: true,
      skip_special_tokens: true,
      callback_function: (token: string) => {
        if (token && isValidText(token)) {
          tokenCount++;
          fullText += token;
          postMessage({ type: 'token', payload: token });
          if (tokenCount <= 3 || tokenCount % 20 === 0) {
            log(`token #${tokenCount} at ${((Date.now() - startMs) / 1000).toFixed(1)}s: "${token.slice(0, 30)}"`);
          }
        }
      },
    });

    log('calling generator pipeline (max_new_tokens=64, timeout=120s)...');

    // Wrap in a timeout so we can detect hangs instead of waiting forever
    const timeoutMs = 120_000;
    const genPromise = generator(messages as any, {
      max_new_tokens: 64, // Start small to test if generation works at all
      temperature: 0.3,
      top_p: 0.9,
      do_sample: true,
      repetition_penalty: 1.2,
      return_full_text: false,
      streamer,
    } as any);

    const timeoutPromise = new Promise((_, reject) =>
      setTimeout(() => reject(new Error(`Generation timed out after ${timeoutMs / 1000}s — model may be too large for this device`)), timeoutMs)
    );

    const output = await Promise.race([genPromise, timeoutPromise]);

    log(`pipeline returned — streamed ${tokenCount} tokens in ${Date.now() - startMs}ms`);

    // Fallback: if streaming produced nothing, extract from output directly
    if (!fullText && output) {
      log('streamer produced no tokens — using fallback output extraction');
      log(`output type: ${typeof output}, isArray=${Array.isArray(output)}`);
      const result = Array.isArray(output) ? output[0] : output;
      log(`result keys: ${JSON.stringify(Object.keys(result ?? {}))}`);
      const generated = (result as any)?.generated_text;
      log(`generated_text type: ${typeof generated}, isArray=${Array.isArray(generated)}`);
      if (typeof generated === 'string') {
        fullText = generated;
      } else if (Array.isArray(generated)) {
        const last = generated[generated.length - 1];
        fullText = last?.content ?? '';
      }
      if (fullText) {
        log(`fallback extracted ${fullText.length} chars: "${fullText.slice(0, 80)}..."`);
        postMessage({ type: 'token', payload: fullText });
      } else {
        log('fallback extraction also empty!');
        log(`raw output: ${JSON.stringify(output).slice(0, 500)}`);
      }
    }

    log(`generate() done — ${fullText.length} chars total`);
    postMessage({ type: 'done', payload: fullText });
  } catch (err: any) {
    if (err?.name === 'AbortError') {
      log('generate() aborted by user');
      postMessage({ type: 'done', payload: '[aborted]' });
    } else {
      log(`generate() ERROR: ${err?.message ?? String(err)}`);
      log(`stack: ${err?.stack ?? 'no stack'}`);
      postMessage({ type: 'error', payload: err?.message ?? String(err) });
    }
  } finally {
    clearInterval(heartbeat);
    abortController = null;
  }
}
